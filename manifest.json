{
  "extension": {
    "name": "Mi Extensión",
    "version": "1.0.0",
    "description": "Extensión de ejemplo para SmartConsole R82.10",
    "author": "secappdm03",
    "provider": "secappdm03",
    "license": "MIT",
    "extension-version-requirements": {
      "minimum-version": "1.3"
    }
  },
  "client-extensions-api": {
    "version": "1.3"
  },
  "management-server-api": {
    "version": "1.3"
  },
  "locations": [
    {
      "location": "tab",
      "relevant-types": ["gateway", "checkpoint-host", "network", "host"],
      "ui-element": {
        "type": "tab",
        "caption": "Mi Pestaña",
        "tooltip": "Información personalizada",
        "action": {
          "url": "myTab.html",
          "details-level": "full",
          "method": "get"
        }
      }
    }
  ],
  "requested-permissions": {
    "client": ["get-read-only-session", "run-read-only-commands"]
  }
}

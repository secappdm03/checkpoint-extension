{
  "extension": {
    "name": "Appliance Info Viewer",
    "version": "1.0.0",
    "description": "Shows important appliance information and current security policies",
    "author": "Your Name",
    "email": "your-email@example.com",
    "product-url": "https://github.com/secappdm03/checkpoint-extension",
    "provider": "secappdm03",
    "license": "GPL",
    "extension-version-requirements": {
      "minimum-version": "1.3"
    }
  },
  "client-extensions-api": {
    "version": "1.3"
  },
  "management-server-api": {
    "version": "1.3"
  },
  "locations": [
    {
      "location": "context-menu",
      "relevant-types": ["gateway"],
      "ui-element": {
        "type": "menu",
        "caption": "Appliance Info",
        "tooltip": "Show gateway information and policies",
        "action": {
          "browser-window": {
            "width": 800,
            "height": 600,
            "min-width": 600,
            "min-height": 400,
            "resizable": true,
            "modal-dialog": false
          },
          "details-level": "full",
          "method": "get",
          "trigger-id": "appliance-info-viewer",
          "disable-automatic-refresh": false,
          "url": "appliance-info.html"
        }
      }
    }
  ],
  "requested-permissions": {
    "client": ["get-read-only-session", "run-read-only-commands"]
  }
}
